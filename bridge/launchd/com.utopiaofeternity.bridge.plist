<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.utopiaofeternity.bridge</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/macbook/Library/Application Support/UtopiaOfEternity/run-bridge.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/macbook/Library/Application Support/UtopiaOfEternity</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/utopia-bridge.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/utopia-bridge.err</string>
</dict>
</plist>
